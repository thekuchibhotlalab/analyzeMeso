            subplot(length(tempTrialType),length(tempActPlot),j + length(tempActPlot)*(i-1));
            plot(smoothdata(tempActPlot{j}(nNeuron,:),'movmean',4)); hold on;
            xline(20)
             
               
             
    
        end 
    end 
end 

