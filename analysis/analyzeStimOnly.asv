figure;  for i = 1:length(selIndexOut); cdfplot(selIndexOut{i}); hold on; end 
legend(cat(2,types,'non-responsive'),'Location','Best'); xlabel('D-prime between L vs. R tone'); xlim([-2 2])

session1 = 166;
