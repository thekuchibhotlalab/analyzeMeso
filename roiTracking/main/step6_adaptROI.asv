%% try this

[roiFinal, ishereFinal,alignIdx1Mean,alignIdx2Mean] = projectROI(stackROI, alignedOps.suite2pImg, ops.offsetMap,refImg_roiReference, ops.refStackSelLoc);
save(stackROI_)
%% old code
